            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const setCookie = pm.response.headers.get('Set-Cookie');",
                  "if (setCookie) {",
                  "  const match = setCookie.match(/X-Session-Id=([^;]+)/);",
                  "  if (match) pm.collectionVariables.set('session_id', match[1]);",
